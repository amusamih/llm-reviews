# Copy to .env locally if desired. Do not commit real secrets.

# Use mock for offline tests. Use langchain only after live-call approval.
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_RETRIEVAL_BACKEND=lexical

# Live calls are disabled by default and require explicit approval.
ALLOW_LIVE_LLM=false
ALLOW_LIVE_RETRIEVAL=false

# OpenAI key is needed only when LLM_PROVIDER=langchain/openai and ALLOW_LIVE_LLM=true.
OPENAI_API_KEY=

# Anthropic is used only for approved model-substitution runs.
# Claude Sonnet 4.6 API model ID.
# Model-substitution live calls remain disabled until explicitly approved.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-6

# Hugging Face endpoint comparisons use hosted inference/API endpoints, not local loading.
# One Hugging Face token can access multiple deployed endpoints when your account has access.
HF_TOKEN=
HUGGINGFACEHUB_API_TOKEN=

# Each deployed Hugging Face model has its own endpoint URL.
HF_QWEN_ENDPOINT_URL=
HF_LLAMA_ENDPOINT_URL=

# Approved model-substitution targets.
OPENAI_GPT4O_MODEL_LABEL=GPT-4o
ANTHROPIC_SONNET_MODEL_LABEL=Claude Sonnet 4.6
HF_MODEL_QWEN=Qwen/Qwen2.5-72B-Instruct
# Llama is deployed through a GGUF/catalog endpoint but should be reported as Llama-3.3-70B-Instruct-compatible.
HF_MODEL_LLAMA=lmstudio-community/Llama-3.3-70B-Instruct-GGUF
HF_MODEL_LLAMA_REPORT_LABEL=meta-llama/Llama-3.3-70B-Instruct compatible GGUF endpoint

REVIEWS_DB_PATH=data/reviews.db
OUTPUT_DIR=outputs
VECTORSTORE_DIR=data/vectorstores
LOG_LEVEL=INFO
